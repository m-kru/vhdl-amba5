namespace eval vhdl::amba5 {
  namespace eval data {
    set doc "Package with data types of different widths."

    proc src {} {
      hbs::SetLib "amba5"
      hbs::AddFile data.vhd
    }

    hbs::Register $doc
  }

  namespace eval string {
    set doc "Package with helper fixed string type."

    proc src {} {
      hbs::SetLib "amba5"
      hbs::AddFile string.vhd
    }

    hbs::Register $doc
  }
}
