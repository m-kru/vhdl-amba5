namespace eval vhdl::amba5::axi-stream {
  namespace eval pkg {
    set doc "AXI-Stream package with all primary types and functions."

    proc src {} {
      hbs::AddDep vhdl::amba5::data::src
      hbs::SetLib "amba5_axi_stream"
      hbs::AddFile axi-stream.vhd
    }

    proc _tb {top} {
      hbs::SetTool "nvc"
      if {$hbs::Tool eq "nvc"} {
        hbs::AddPreSimCb hbs::SetArgPrefix "--messages=compact"
      }
      hbs::SetTop $top
      src
      hbs::SetLib ""
    }

    # Testbench for interface errors functions.
    proc tb-errors-functions {} {
      _tb "tb_errors_functions"
      hbs::SetExitSeverity "failure"
      hbs::AddFile tb/tb-errors-functions.vhd
      hbs::Run
    }

    # Testbench for interface warnings functions.
    proc tb-warnings-functions {} {
      _tb "tb_warnings_functions"
      hbs::AddFile tb/tb-warnings-functions.vhd
      hbs::Run
    }

    # Testbench for to_debug functions.
    proc tb-stream-to-debug {} {
      _tb "tb_stream_to_debug"
      hbs::AddFile tb/tb-stream-to_debug.vhd
      hbs::Run
    }

    hbs::Register $doc
  }

  namespace eval checker {
    set doc "AXI Steram interface checker core.
It detects erroneous and unrecommended scenarios on the interface."

    proc src {} {
      hbs::AddDep vhdl::amba5::string::src
      hbs::AddDep vhdl::amba5::axi-stream::pkg::src
      hbs::SetLib "amba5_axi_stream"
      hbs::AddFile checker.vhd
    }

    proc _tb {top} {
      hbs::SetTool "nvc"
      if {$hbs::Tool eq "nvc"} {
        hbs::AddPreSimCb hbs::SetArgPrefix "--messages=compact"
      }
      hbs::SetTop $top
      src
      hbs::SetLib ""
    }

    # Testbench for errors detection logic.
    proc tb-detect-errors {} {
      _tb "tb_detect_errors"
      hbs::AddFile tb/checker/tb-detect-errors.vhd
      hbs::SetExitSeverity "failure"
      hbs::Run
    }

    # Testbench for warnings detection logic.
    proc tb-detect-warnings {} {
      _tb "tb_detect_warnings"
      hbs::AddFile tb/checker/tb-detect-warnings.vhd
      hbs::Run
    }

    hbs::Register $doc
  }

  namespace eval bfm {
    set doc "Bus Functional Model.
It is useful only for simulations."

    proc src {} {
      hbs::AddDep vhdl::amba5::data::src
      hbs::AddDep vhdl::amba5::string::src
      hbs::AddDep vhdl::amba5::axi-stream::pkg::src
      hbs::SetLib "amba5_axi_stream"
      hbs::AddFile bfm.vhd
    }

    proc _tb {top} {
      hbs::SetTool "nvc"
      hbs::AddDep vhdl::amba5::axi-stream::checker::src
      if {$hbs::Tool eq "nvc"} {
        hbs::AddPreSimCb hbs::SetArgPrefix "--messages=compact"
      }
      hbs::SetExitSeverity "warning"
      hbs::SetTop $top
      src
      hbs::SetLib ""
    }

    proc tb-stream8-transmit {} {
      _tb "tb_stream8_transmit"
      hbs::AddFile tb/bfm/tb-stream8-transmit.vhd
      hbs::Run
    }

    hbs::Register $doc
  }

  namespace eval packet-dropper {
    set doc "ToDo"

    proc src {} {
      hbs::AddDep vhdl::amba5::string::src
      hbs::AddDep vhdl::amba5::axi-stream::pkg::src
      hbs::SetLib "amba5_axi_stream"
      hbs::AddFile packet-dropper.vhd
    }

    proc _tb {top} {
      hbs::SetTool "nvc"
      if {$hbs::Tool eq "nvc"} {
        hbs::AddPreSimCb hbs::SetArgPrefix "--messages=compact"
        hbs::AddPreSimCb hbs::SetArgSuffix "--dump-arrays"
      }
      hbs::AddDep vhdl::amba5::axi-stream::bfm::src
      hbs::AddDep vhdl::amba5::axi-stream::checker::src
      hbs::SetTop $top
      src
      hbs::SetLib ""
    }

    proc tb-stream8-basic-back-pressure-and-drop {} {
      _tb "tb_stream8_basic_back_pressure_and_drop"
      hbs::AddFile tb/packet-dropper/tb-stream8-basic-back-pressure-and-drop.vhd
      hbs::Run
    }

    proc tb-stream8-transmitter-not-always-valid {} {
      _tb "tb_stream8_transmitter_not_always_valid"
      hbs::AddFile tb/packet-dropper/tb-stream8-transmitter-not-always-valid.vhd
      hbs::Run
    }

    proc tb-stream8-id-dest {} {
      _tb "tb_stream8_id_dest"
      hbs::AddFile tb/packet-dropper/tb-stream8-id-dest.vhd
      hbs::Run
    }

    proc tb-stream8-receiver-ready-after-valid {} {
      _tb "tb_stream8_receiver_ready_after_valid"
      hbs::AddFile tb/packet-dropper/tb-stream8-receiver-ready-after-valid.vhd
      hbs::Run
    }

    proc tb-stream16-no-back-pressure-no-drop {} {
      _tb "tb_stream16_no_back_pressure_no_drop"
      hbs::AddFile tb/packet-dropper/tb-stream16-no-back-pressure-no-drop.vhd
      hbs::Run
    }

    proc tb-stream32-drop-every-other {} {
      _tb "tb_stream32_drop_every_other"
      hbs::AddFile tb/packet-dropper/tb-stream32-drop-every-other.vhd
      hbs::Run
    }

    proc tb-stream64-drop-all-single-transfer {} {
      _tb "tb_stream64_drop_all_single_transfer"
      hbs::AddFile tb/packet-dropper/tb-stream64-drop-all-single-transfer.vhd
      hbs::Run
    }

    proc tb-stream128-all-single-transfer-drop-one {} {
      _tb "tb_stream128_all_single_transfer_drop_one"
      hbs::AddFile tb/packet-dropper/tb-stream128-all-single-transfer-drop-one.vhd
      hbs::Run
    }

    proc tb-stream256-all-single-transfer-forward-one {} {
      _tb "tb_stream256_all_single_transfer_forward_one"
      hbs::AddFile tb/packet-dropper/tb-stream256-all-single-transfer-forward-one.vhd
      hbs::Run
    }

    hbs::Register $doc
  }

}
